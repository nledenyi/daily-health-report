# --- Temperatures ---
# Depends on: SMART_DATA (from check_disks)
# Exports: TEMP_DATA, DISK_TEMP_RANGE
check_temperatures() {
    CPU_TEMP=$(sensors 2>/dev/null | grep 'Package id 0:' | grep -oE '\+[0-9.]+' | head -1 | tr -d '+')
    NVME_TEMP=$(sensors 2>/dev/null | grep 'Composite:' | grep -oE '\+[0-9.]+' | head -1 | tr -d '+')
    GPU_TEMP=$(nvidia-smi --query-gpu=temperature.gpu --format=csv,noheader 2>/dev/null | head -1)
    AMD_GPU_TEMP="" AMD_GPU_POWER="" AMD_GPU_VRAM_USED="" AMD_GPU_VRAM_TOTAL="" AMD_GPU_SLEEP=""
    for hwmon in /sys/class/drm/card*/device/hwmon/hwmon*; do
        [ -f "$hwmon/name" ] || continue
        driver=$(cat "$hwmon/name" 2>/dev/null)
        if [ "$driver" = "amdgpu" ]; then
            card_dev=$(dirname "$hwmon" | sed 's|/hwmon$||')
            runtime_status=$(cat "$card_dev/power/runtime_status" 2>/dev/null)
            if [ "$runtime_status" = "suspended" ]; then
                AMD_GPU_SLEEP="yes"
            else
                raw=$(cat "$hwmon/temp1_input" 2>/dev/null)
                [ -n "$raw" ] && AMD_GPU_TEMP=$((raw / 1000))
                if [ -f "$hwmon/power1_average" ]; then
                    raw_pwr=$(cat "$hwmon/power1_average" 2>/dev/null)
                    [ -n "$raw_pwr" ] && AMD_GPU_POWER=$((raw_pwr / 1000000))
                fi
            fi
            if [ -f "$card_dev/mem_info_vram_used" ]; then
                vram_used_raw=$(cat "$card_dev/mem_info_vram_used" 2>/dev/null)
                vram_total_raw=$(cat "$card_dev/mem_info_vram_total" 2>/dev/null)
                [ -n "$vram_used_raw" ] && AMD_GPU_VRAM_USED=$((vram_used_raw / 1048576))
                [ -n "$vram_total_raw" ] && AMD_GPU_VRAM_TOTAL=$((vram_total_raw / 1048576))
            fi
            break
        fi
    done
    if [ -n "$AMD_GPU_TEMP" ] && [ "$AMD_GPU_TEMP" -ge 95 ]; then
        emit_issue CRIT "AMD GPU (R9700) at ${AMD_GPU_TEMP}°C — throttling likely"
    elif [ -n "$AMD_GPU_TEMP" ] && [ "$AMD_GPU_TEMP" -ge 85 ]; then
        emit_issue WARN "AMD GPU (R9700) at ${AMD_GPU_TEMP}°C — running hot"
    fi
    NIC_TEMP=$(sensors 2>/dev/null | grep 'MAC Temperature:' | grep -oE '\+[0-9.]+' | head -1 | tr -d '+')
    DISK_TEMP_MIN="" DISK_TEMP_MAX=""
    while IFS='|' read -r _disk _health temp _hours _errors; do
        t=$(echo "$temp" | grep -oE '[0-9]+')
        [ -z "$t" ] && continue
        [ -z "$DISK_TEMP_MIN" ] && DISK_TEMP_MIN=$t DISK_TEMP_MAX=$t
        [ "$t" -lt "$DISK_TEMP_MIN" ] && DISK_TEMP_MIN=$t
        [ "$t" -gt "$DISK_TEMP_MAX" ] && DISK_TEMP_MAX=$t
    done <<< "$(echo -e "$SMART_DATA")"
    if [ -n "$DISK_TEMP_MIN" ]; then
        if [ "$DISK_TEMP_MIN" -eq "$DISK_TEMP_MAX" ]; then
            DISK_TEMP_RANGE="${DISK_TEMP_MIN}°C"
        else
            DISK_TEMP_RANGE="${DISK_TEMP_MIN}–${DISK_TEMP_MAX}°C"
        fi
    fi
    TEMP_DATA=""
    [ -n "$CPU_TEMP" ] && TEMP_DATA="${TEMP_DATA}CPU Package|${CPU_TEMP}°C\n"
    [ -n "$NVME_TEMP" ] && TEMP_DATA="${TEMP_DATA}NVMe (Kingston)|${NVME_TEMP}°C\n"
    [ -n "$GPU_TEMP" ] && TEMP_DATA="${TEMP_DATA}GPU (GTX 1660 SUPER)|${GPU_TEMP}°C\n"
    if [ "$AMD_GPU_SLEEP" = "yes" ]; then
        AMD_GPU_LINE="GPU (R9700)|sleep"
        if [ -n "$AMD_GPU_VRAM_USED" ]; then
            AMD_VRAM_G=$(awk "BEGIN {printf \"%.0f\", $AMD_GPU_VRAM_USED/1024}")
            AMD_VRAM_T=$(awk "BEGIN {printf \"%.0f\", $AMD_GPU_VRAM_TOTAL/1024}")
            AMD_GPU_LINE="${AMD_GPU_LINE}, ${AMD_VRAM_G}/${AMD_VRAM_T}G VRAM"
        fi
        TEMP_DATA="${TEMP_DATA}${AMD_GPU_LINE}\n"
    elif [ -n "$AMD_GPU_TEMP" ]; then
        AMD_GPU_LINE="GPU (R9700)|${AMD_GPU_TEMP}°C"
        [ -n "$AMD_GPU_POWER" ] && AMD_GPU_LINE="${AMD_GPU_LINE}, ${AMD_GPU_POWER}W"
        if [ -n "$AMD_GPU_VRAM_USED" ]; then
            AMD_VRAM_G=$(awk "BEGIN {printf \"%.0f\", $AMD_GPU_VRAM_USED/1024}")
            AMD_VRAM_T=$(awk "BEGIN {printf \"%.0f\", $AMD_GPU_VRAM_TOTAL/1024}")
            AMD_GPU_LINE="${AMD_GPU_LINE}, ${AMD_VRAM_G}/${AMD_VRAM_T}G"
        fi
        TEMP_DATA="${TEMP_DATA}${AMD_GPU_LINE}\n"
    fi
    [ -n "$NIC_TEMP" ] && TEMP_DATA="${TEMP_DATA}10G NIC (Aquantia)|${NIC_TEMP}°C\n"
    [ -n "$DISK_TEMP_RANGE" ] && TEMP_DATA="${TEMP_DATA}Disks|${DISK_TEMP_RANGE}\n"
}
check_temperatures

# --- System Summary ---
# Exports: UPTIME, LOAD, MEM_USED, PVE_VER, KERNEL_VER, UPGRADABLE_COUNT
gather_system_summary() {
    UPTIME=$(uptime -p)
    LOAD=$(cat /proc/loadavg | awk '{print $1, $2, $3}')
    MEM_USED=$(free -h | awk '/Mem:/ {print $3 "/" $2}')

    PVE_VER=$(pveversion 2>/dev/null | cut -d'/' -f2)
    KERNEL_VER=$(uname -r)
    LATEST_KERNEL_PKG=$(dpkg -l 'proxmox-kernel-[0-9]*' 2>/dev/null | awk '/^ii.*pve-signed/ {print $2}' | sort -V | tail -1)
    LATEST_KERNEL_VER=$(echo "$LATEST_KERNEL_PKG" | sed 's/proxmox-kernel-//;s/-signed//')
    if [ -n "$LATEST_KERNEL_VER" ] && [ "$LATEST_KERNEL_VER" != "$KERNEL_VER" ]; then
        KERNEL_VER="${KERNEL_VER} (${LATEST_KERNEL_VER} available)"
    fi
    INSTALLED_PVE=$(dpkg -l pve-manager 2>/dev/null | awk '/^ii/{print $3}')
    LATEST_PVE=$(apt-cache policy pve-manager 2>/dev/null | awk '/Candidate:/{print $2}')
    if [ -n "$LATEST_PVE" ] && [ -n "$INSTALLED_PVE" ] && [ "$LATEST_PVE" != "$INSTALLED_PVE" ]; then
        PVE_VER="${PVE_VER} (${LATEST_PVE} available)"
    fi
    UPGRADABLE_COUNT=$(apt-get -s dist-upgrade 2>/dev/null | grep -c ^Inst)
}
gather_system_summary

