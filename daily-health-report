ALL_SMART_PASSED=true
ALL_ERRORS_ZERO=true
ALL_POOLS_ONLINE=true
while IFS='|' read -r disk health temp hours errors; do
    [ -z "$disk" ] && continue
    if [ "$health" != "PASSED" ] && [ "$health" != "OK" ]; then ALL_SMART_PASSED=false; fi
    uncorr="${errors%%/*}"; realloc="${errors##*/}"
    if [ "$uncorr" != "0" ] || [ "$realloc" != "0" ]; then ALL_ERRORS_ZERO=false; fi
done <<< "$(echo -e "$SMART_DATA")"
while IFS='|' read -r pool size alloc free cap health; do
    [ -z "$pool" ] && continue
    if [ "$health" != "ONLINE" ] && [ "$health" != "ext4" ]; then ALL_POOLS_ONLINE=false; fi
done <<< "$(echo -e "$POOL_DATA")"

# Compact uptime for header: "up 1 week, 4 days, 14 hours, 49 minutes" -> "11d 14h"
UPTIME_SECS_TOTAL=$(awk '{print int($1)}' /proc/uptime)
_up_d=$((UPTIME_SECS_TOTAL / 86400))
_up_h=$(( (UPTIME_SECS_TOTAL % 86400) / 3600 ))
_up_m=$(( (UPTIME_SECS_TOTAL % 3600) / 60 ))
if [ "$_up_d" -gt 0 ]; then
    UPTIME_COMPACT="up ${_up_d}d ${_up_h}h"
elif [ "$_up_h" -gt 0 ]; then
    UPTIME_COMPACT="up ${_up_h}h ${_up_m}m"
else
    UPTIME_COMPACT="up ${_up_m}m"
fi

# Shorten component names for temperatures
TEMP_DATA_SHORT=$(echo -e "$TEMP_DATA" | sed \
    -e 's/CPU Package/CPU/' \
    -e 's/NVMe (Kingston)/NVMe/' \
    -e 's/GPU (GTX 1660 SUPER)/1660S/' \
    -e 's/GPU (R9700)/R9700/' \
    -e 's/10G NIC (Aquantia)/10G NIC/')

HTML="<!DOCTYPE html>
<html>
<head>
<style>
  body { font-family: -apple-system, 'Segoe UI', Arial, sans-serif; background: #1a1a2e; margin: 0; padding: 8px; }
  .container { max-width: 600px; margin: 0 auto; background: #16213e; border-radius: 8px; overflow: hidden; }
  .header { background: ${STATUS_COLOR}; color: #fff; padding: 12px; }
  .header h1 { margin: 0; font-size: 17px; font-weight: 600; }
  .header p { margin: 2px 0 0; opacity: 0.9; font-size: 12px; }
  .body { padding: 8px; }
  .section { margin-bottom: 12px; }
  .section h2 { font-size: 11px; color: #8892b0; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 6px; border-bottom: 1px solid #233554; padding-bottom: 4px; }
  .note { font-size: 10px; color: #2ecc71; margin: -4px 0 4px; }
  .note-warn { font-size: 10px; color: #e67e22; margin: -4px 0 4px; }
  table { width: 100%; border-collapse: collapse; font-size: 11px; color: #ccd6f6; }
  th { text-align: left; padding: 3px 4px; font-weight: 600; color: #8892b0; font-size: 10px; border-bottom: 1px solid #233554; }
  td { padding: 3px 4px; border-bottom: 1px solid #0a192f; }
  .g { color: #2ecc71; }
  .r { color: #e74c3c; font-weight: 600; }
  .y { color: #e67e22; font-weight: 600; }
  .dim { color: #5a6785; }
  .badge { display: inline-block; padding: 1px 5px; border-radius: 3px; font-size: 10px; font-weight: 600; }
  .badge-crit { background: #e74c3c22; color: #e74c3c; }
  .badge-warn { background: #e67e2222; color: #e67e22; }
  .badge-ok { background: #2ecc7122; color: #2ecc71; }
  .badge-info { background: #3498db22; color: #3498db; }
  .footer { padding: 6px 12px; font-size: 10px; color: #5a6785; text-align: center; }
</style>
</head>
<body>
<div class='container'>
  <div class='header'>
    <h1>${STATUS_ICON_HTML} ${HOSTNAME} Daily Health Report</h1>
    <p>${DATE} | ${UPTIME_COMPACT}</p>
  </div>
  <div class='body'>"

# Issues section
if [ ${#ISSUES[@]} -gt 0 ]; then
    HTML="${HTML}
    <div class='section'><h2>Issues</h2>"
    for issue in "${ISSUES[@]}"; do
        severity="${issue%%|*}"
        msg="${issue#*|}"
        case "$severity" in
            CRIT) badge="badge-crit" ;;
            WARN) badge="badge-warn" ;;
            INFO) badge="badge-info" ;;
            *)    badge="badge-ok" ;;
        esac
        HTML="${HTML}<div style='margin:2px 0;font-size:11px;color:#ccd6f6'><span class='badge ${badge}'>${severity}</span> ${msg}</div>"
    done
    HTML="${HTML}</div>"
fi

# Storage section — drop Health column if all healthy
HTML="${HTML}
    <div class='section'>
      <h2>Storage Pools</h2>"
if $ALL_POOLS_ONLINE; then
    HTML="${HTML}<div class='note'>&#9989; All pools healthy</div>"
fi
HTML="${HTML}
      <table>
        <tr><th>Pool</th><th>Size</th><th>Used</th><th>Free</th><th>%</th></tr>"
HTML="${HTML}$(echo -e "$POOL_DATA" | while IFS='|' read -r pool size alloc free cap health; do
    [ -z "$pool" ] && continue
    cap_num=${cap%\%}
    if [ "$cap_num" -ge 90 ]; then s="class='r'"
    elif [ "$cap_num" -ge 80 ]; then s="class='y'"
    else s="class='g'"
    fi
    echo "<tr><td><strong>${pool}</strong></td><td>${size}</td><td>${alloc}</td><td>${free}</td><td ${s}>${cap}</td></tr>"
done)
      </table>
    </div>"

# Disk health section — normalize SMART & errors columns
HTML="${HTML}
    <div class='section'>
      <h2>Disks (SMART)</h2>"
if $ALL_SMART_PASSED && $ALL_ERRORS_ZERO; then
    HTML="${HTML}<div class='note'>&#9989; All disks PASSED, 0 errors</div>"
fi
HTML="${HTML}
      <table>
        <tr><th>Disk</th><th></th><th>Temp</th><th>Age</th>"
if ! $ALL_ERRORS_ZERO; then HTML="${HTML}<th>Err</th>"; fi
HTML="${HTML}</tr>"
while IFS='|' read -r disk health temp hours errors; do
    [ -z "$disk" ] && continue
    short_disk=${disk#/dev/}
    if [ "$health" = "PASSED" ] || [ "$health" = "OK" ]; then icon="&#128994;"
    elif [ "$health" = "N/A" ]; then icon="&#128994;"
    else icon="&#128308;"; fi
    row="<tr><td>${short_disk}</td><td>${icon}</td><td>${temp}</td><td>${hours}</td>"
    if ! $ALL_ERRORS_ZERO; then
        uncorr="${errors%%/*}"; realloc="${errors##*/}"
        if [ "$uncorr" = "0" ] && [ "$realloc" = "0" ]; then row="${row}<td class='g'>0</td>"
        else row="${row}<td class='r'>${errors}</td>"; fi
    fi
    HTML="${HTML}${row}</tr>"
done <<< "$(echo -e "$SMART_DATA")"
HTML="${HTML}
      </table>
    </div>"

# Guests section — no ID column, emoji status
HTML="${HTML}
    <div class='section'>
      <h2>VMs &amp; Containers</h2>
      <table>
        <tr><th>Name</th><th></th><th>Mem</th><th>Disk</th></tr>"
HTML="${HTML}$(echo -e "$GUEST_DATA" | while IFS='|' read -r name status mem disk; do
    [ -z "$name" ] && continue
    if [ "$status" = "running" ]; then icon="&#128994;"; else icon="&#9898;"; fi
    echo "<tr><td>${name}</td><td>${icon}</td><td>${mem}</td><td>${disk}</td></tr>"
done)
      </table>
    </div>"

# Docker services section (VM 104)
if [ "$DOCKER_CRIT_COUNT" -gt 0 ] || [ "$DOCKER_OTHER_TOTAL" -gt 0 ]; then
    HTML="${HTML}
    <div class='section'>
      <h2>Docker Services (VM 104 + LXC 105)</h2>
      <table>
        <tr><th>Service</th><th></th></tr>"
    while IFS='|' read -r dname dstate; do
        [ -z "$dname" ] && continue
        if [ "$dstate" = "running" ]; then icon="&#128994;"; else icon="&#128308;"; fi
        HTML="${HTML}<tr><td>${dname}</td><td>${icon}</td></tr>"
    done <<< "$(echo -e "$DOCKER_CRIT_DATA")"
    # Stopped container details
    DOCKER_STOPPED=$((DOCKER_OTHER_TOTAL - DOCKER_OTHER_RUNNING))
    if [ "$DOCKER_STOPPED" -gt 0 ]; then
        while IFS='|' read -r sname sreason; do
            [ -z "$sname" ] && continue
            if echo "$sreason" | grep -qE "crashed|crash loop"; then
                icon="&#128308;"; cls="r"
            else
                icon="&#9898;"; cls="dim"
            fi
            HTML="${HTML}<tr><td class='${cls}'>${sname}</td><td>${icon} <span class='${cls}' style='font-size:10px'>${sreason}</span></td></tr>"
        done <<< "$(echo -e "$DOCKER_STOPPED_DATA")"
    fi
    HTML="${HTML}
      </table>
      <div style='font-size:10px;color:#8892b0;margin-top:4px'>+ ${DOCKER_OTHER_RUNNING} other running</div>
    </div>"
fi


# Ollama section (LXC 106)
if [ "$OLLAMA_OK" = "ok" ]; then
    # GPU offload styling
    case "$OLLAMA_GPU_OFFLOAD" in
        *"100% GPU"*) GPU_CLS="g" ;;
        *"CPU only"*) GPU_CLS="r" ;;
        "idle")       GPU_CLS="dim" ;;
        *)            GPU_CLS="y" ;;
    esac
    # Error rate styling
    if [ "$OLLAMA_ERR_24H" -gt 0 ] 2>/dev/null; then
        ERR_CLS="r"
    else
        ERR_CLS="g"
    fi
    HTML="${HTML}
    <div class='section'>
      <h2>Ollama (LXC 106)</h2>
      <table>
        <tr><td><strong>Version</strong></td><td>${OLLAMA_VERSION}$([ -n "$OLLAMA_UPDATE_AVAIL" ] && echo " <span class='y'>(${OLLAMA_UPDATE_AVAIL} available)</span>")</td></tr>
        <tr><td><strong>Models</strong></td><td>${OLLAMA_MODELS_COUNT} installed (${OLLAMA_MODELS_SIZE})</td></tr>
        <tr><td><strong>Loaded</strong></td><td>${OLLAMA_LOADED_MODELS}</td></tr>
        <tr><td><strong>GPU Offload</strong></td><td><span class='${GPU_CLS}'>${OLLAMA_GPU_OFFLOAD}</span></td></tr>
        <tr><td><strong>Requests (24h)</strong></td><td>${OLLAMA_REQ_24H} (<span class='${ERR_CLS}'>${OLLAMA_ERR_24H} errors</span>)</td></tr>
        <tr><td><strong>Avg Duration</strong></td><td>${OLLAMA_AVG_DURATION}</td></tr>
        <tr><td><strong>Idle</strong></td><td>${OLLAMA_IDLE_TIME}</td></tr>"
    [ -n "$OLLAMA_CLIENTS" ] && HTML="${HTML}
        <tr><td><strong>Clients</strong></td><td>${OLLAMA_CLIENTS}</td></tr>"
    if [ "$OLLAMA_TOKENS_GENERATED" != "0" ] || [ "$OLLAMA_TOKENS_PROMPT" != "0" ]; then
        HTML="${HTML}
        <tr><td><strong>Tokens</strong></td><td>${OLLAMA_TOKENS_GENERATED} out / ${OLLAMA_TOKENS_PROMPT} in</td></tr>
        <tr><td><strong>Throughput</strong></td><td>${OLLAMA_TOK_PER_SEC} tok/s</td></tr>"
    fi
    HTML="${HTML}
      </table>
    </div>"
else
    HTML="${HTML}
    <div class='section'>
      <h2>Ollama (LXC 106)</h2>
      <div style='font-size:11px;color:#e74c3c'>&#10060; Not responding</div>
    </div>"
fi

# Maintenance section — compact two-column layout
if [ "$SANOID_COVERED_DS" = "$SANOID_TOTAL_DS" ]; then
    COV_CLS="g"
else
    COV_CLS="y"
fi
if [ "$VZDUMP_VMIDS" = "$TOTAL_GUESTS" ]; then
    VZDUMP_CLS="g"
else
    VZDUMP_CLS="y"
fi

# Unattended-upgrades detail for HTML
UAU_DETAIL=""
if [ "$UAU_REBOOT_REQUIRED" = "yes" ]; then
    UAU_DETAIL=" <span class='badge badge-warn'>reboot</span>"
elif [ "$UAU_PKG_COUNT" -gt 0 ]; then
    UAU_DETAIL=" (${UAU_PKG_COUNT} pkgs)"
fi

# Status emoji helper
_html_status_icon() {
    if [ "$1" = "ok" ] || [ "$1" = "OK" ] || [ "$1" = "0" ]; then echo "&#9989;"; else echo "&#10060;"; fi
}

HTML="${HTML}
    <div class='section'>
      <h2>Maintenance</h2>
      <table>
        <tr><th>Task</th><th>Last</th><th></th></tr>
        <tr><td>Sanoid</td><td>${SANOID_LAST_FMT}</td><td>$(_html_status_icon "$SANOID_LAST_EXIT") <span class='${COV_CLS}'>${SANOID_COVERED_DS}/${SANOID_TOTAL_DS}</span></td></tr>
        <tr><td>Syncoid</td><td>${SYNCOID_SVC_LAST_FMT}</td><td>$(_html_status_icon "$SYNCOID_SVC_LAST_EXIT")</td></tr>
        <tr><td>Vzdump</td><td>${VZDUMP_LAST_FMT}</td><td>&#9989; <span class='${VZDUMP_CLS}'>${VZDUMP_VMIDS}/${TOTAL_GUESTS}</span> weekly</td></tr>
        <tr><td>Upgrades</td><td>${UAU_LAST_FMT}</td><td>$(_html_status_icon "$UAU_LAST_EXIT")${UAU_DETAIL}</td></tr>"

# ZFS scrub rows
HTML="${HTML}$(echo -e "$SCRUB_DATA" | while IFS='|' read -r pool scrub_time scrub_errs; do
    [ -z "$pool" ] && continue
    if [ "$scrub_errs" = "0 errors" ] || [ "$scrub_errs" = "—" ]; then
        eicon="&#9989;"
    else
        eicon="&#10060;"
    fi
    echo "        <tr><td>Scrub (${pool})</td><td>${scrub_time}</td><td>${eicon}</td></tr>"
done)
      </table>
    </div>"

# Temperatures — compact inline layout
TEMP_ITEMS=""
while IFS='|' read -r comp temp; do
    [ -z "$comp" ] && continue
    if [ -n "$TEMP_ITEMS" ]; then
        TEMP_ITEMS="${TEMP_ITEMS} <span style='color:#5a6785'>&middot;</span> "
    fi
    TEMP_ITEMS="${TEMP_ITEMS}<strong>${comp}</strong> ${temp}"
done <<< "$(echo -e "$TEMP_DATA_SHORT")"

HTML="${HTML}
    <div class='section'>
      <h2>Temperatures</h2>
      <div style='font-size:11px;color:#ccd6f6;line-height:1.8'>${TEMP_ITEMS}</div>
    </div>"

# System summary — compact key-value pairs
CPU_MODEL=$(grep -m1 'model name' /proc/cpuinfo | cut -d: -f2 | xargs)
CPU_USAGE=$(awk '{printf "%.0f%%", ($1/'"$(nproc)"')*100}' /proc/loadavg)

HTML="${HTML}
    <div class='section'>
      <h2>System</h2>
      <div style='font-size:11px;color:#ccd6f6;line-height:1.8'>
        <strong>PVE</strong> ${PVE_VER}<span style='color:#5a6785'> &middot; </span><strong>Kernel</strong> ${KERNEL_VER}<span style='color:#5a6785'> &middot; </span><strong>Pkgs</strong> ${UPGRADABLE_COUNT} upgradable<span style='color:#5a6785'> &middot; </span><strong>Load</strong> ${LOAD}<span style='color:#5a6785'> &middot; </span><strong>RAM</strong> ${MEM_USED}<span style='color:#5a6785'> &middot; </span><strong>CPU</strong> ${CPU_USAGE}$([ -n "$LXC_UPDATE_SUMMARY" ] && echo "<br/><strong>LXC updates</strong> <span class='y'>${LXC_UPDATE_SUMMARY}</span>")
      </div>
    </div>"

HTML="${HTML}
  </div>
  <div class='footer'>
    ${HOSTNAME} &bull; daily-health-report
  </div>
</div>
</body>
</html>"

echo "$HTML" | mail -a "Content-Type: text/html; charset=UTF-8" -a "From: ${MAIL_FROM}" -s "[${HOSTNAME}] Daily Health: ${STATUS_TEXT}" root
