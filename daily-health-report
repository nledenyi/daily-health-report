#!/bin/bash
# Daily health report for a Proxmox VE host.
# Sends summary via Telegram, HTML email, and appends to a markdown log.
# Environment-specific values (hostnames, IPs, VMIDs, disk serials, email domain,
# paths) live in /etc/daily-health/config — edit that file, not this script.

CONFIG_FILE="${DAILY_HEALTH_CONFIG:-/etc/daily-health/config}"
if [ ! -r "$CONFIG_FILE" ]; then
    echo "daily-health-report: config file not found or unreadable: $CONFIG_FILE" >&2
    echo "See config.example in the distribution for the required fields." >&2
    exit 2
fi
# shellcheck disable=SC1090
source "$CONFIG_FILE"

# Helper: is-in-array. Usage: in_array "needle" "${array[@]}"
in_array() {
    local needle="$1"; shift
    local x
    for x in "$@"; do [ "$x" = "$needle" ] && return 0; done
    return 1
}

HOSTNAME=$(hostname)
DATE=$(date '+%Y-%m-%d %H:%M')
DATE_SHORT=$(date '+%Y-%m-%d')
LOG_FILE="${LOG_DIR}/daily-health.md"
ISSUES=()

mkdir -p "$LOG_DIR"

# Helper: convert hours to Xm Xd Xh
hours_to_mdh() {
    local h=$1
    [ "$h" = "?" ] && echo "?" && return
    h=${h//,/}
    local months=$((h / 730))
    local days=$(( (h % 730) / 24 ))
    local hrs=$((h % 24))
    if [ "$months" -gt 0 ]; then
        echo "${months}m ${days}d"
    elif [ "$days" -gt 0 ]; then
        echo "${days}d ${hrs}h"
    else
        echo "${hrs}h"
    fi
}

# --- Check helpers ---
# emit_issue LEVEL "message" — LEVEL is CRIT | WARN | INFO
emit_issue() {
    ISSUES+=("$1|$2")
}

# SECTIONS registry — populated during Batches 2/3 as sections convert to the
# function-per-section pattern. Entries: "name|title|render_mode|columns"
SECTIONS=()

# ===================== Gather Data =====================

# --- Recent Restart Detection ---
check_recent_restart() {
    local uptime_secs uptime_mins
    uptime_secs=$(awk '{print int($1)}' /proc/uptime)
    if [ "$uptime_secs" -lt 3600 ]; then
        uptime_mins=$((uptime_secs / 60))
        emit_issue WARN "System restarted ${uptime_mins}m ago (possible unplanned reboot)"
    fi
}
check_recent_restart

# --- Storage Pools (ZFS + pve-root) ---
# Exports: POOL_STATUS, POOL_DATA, POOL_OK, POOL_DETAIL, CAP_OK, CAP_DETAIL
check_storage_pools() {
    POOL_OK="ok"; POOL_DETAIL=""
    CAP_OK="ok"; CAP_DETAIL=""

    POOL_STATUS=$(zpool list -H -o name,health)
    while read -r pool health; do
        if [ "$health" != "ONLINE" ]; then
            emit_issue CRIT "Pool $pool is $health"
            POOL_OK="fail"
            POOL_DETAIL="${POOL_DETAIL} ${pool}"
        fi
    done <<< "$POOL_STATUS"

    POOL_DATA=""
    while read -r pool size alloc free cap health; do
        POOL_DATA="${POOL_DATA}${pool}|${size}|${alloc}|${free}|${cap}|${health}\n"
        cap_num=${cap%\%}
        if [ "$cap_num" -ge 90 ]; then
            emit_issue CRIT "Pool $pool at ${cap} capacity"
            CAP_OK="warn"
            CAP_DETAIL="${CAP_DETAIL} ${pool}:${cap}"
        elif [ "$cap_num" -ge 80 ]; then
            emit_issue WARN "Pool $pool at ${cap} capacity"
            CAP_OK="warn"
            CAP_DETAIL="${CAP_DETAIL} ${pool}:${cap}"
        fi
    done <<< "$(zpool list -H -o name,size,alloc,free,cap,health)"

    PVE_ROOT_LINE=$(df -h / 2>/dev/null | tail -1)
    PVE_ROOT_SIZE=$(echo "$PVE_ROOT_LINE" | awk '{print $2}')
    PVE_ROOT_USED=$(echo "$PVE_ROOT_LINE" | awk '{print $3}')
    PVE_ROOT_FREE=$(echo "$PVE_ROOT_LINE" | awk '{print $4}')
    PVE_ROOT_PCT=$(echo "$PVE_ROOT_LINE" | awk '{print $5}')
    PVE_ROOT_PCT_NUM=${PVE_ROOT_PCT%\%}
    POOL_DATA="${POOL_DATA}pve-root|${PVE_ROOT_SIZE}|${PVE_ROOT_USED}|${PVE_ROOT_FREE}|${PVE_ROOT_PCT}|ext4\n"
    if [ "$PVE_ROOT_PCT_NUM" -ge 95 ]; then
        emit_issue CRIT "pve-root at ${PVE_ROOT_PCT} capacity"
    elif [ "$PVE_ROOT_PCT_NUM" -ge 85 ]; then
        emit_issue WARN "pve-root at ${PVE_ROOT_PCT} capacity"
    fi
}
check_storage_pools

# --- Expected Disks (by serial number) ---
# The EXPECTED_DISKS associative array is populated by the config file.
# If any of its serials aren't found among probed disks, we raise CRIT.

# --- SMART Health + Missing Disk Detection ---
# Exports: SMART_DATA, FOUND_SERIALS, SMART_OK, SMART_DETAIL
check_disks() {
    SMART_OK="ok"; SMART_DETAIL=""
    SMART_DATA=""
    FOUND_SERIALS=()
    for disk in /dev/sd? /dev/nvme0; do
        [ -e "$disk" ] || continue
        smartout=$(smartctl -A "$disk" 2>/dev/null)
        smartinfo=$(smartctl -i "$disk" 2>/dev/null)
        serial=$(echo "$smartinfo" | grep -i 'Serial Number' | awk '{print $NF}')
        FOUND_SERIALS+=("$serial")
        health=$(smartctl -H "$disk" 2>/dev/null | grep -E 'overall-health|Status' | grep -oE 'PASSED|FAILED|OK' | head -1)
        temp=$(echo "$smartout" | grep -iE 'temperature|Airflow' | head -1 | awk '{print $10}')
        if [ -z "$temp" ]; then
            temp=$(smartctl -A "$disk" 2>/dev/null | grep -i 'Temperature:' | awk '{print $2}')
        fi
        hours_raw=$(echo "$smartout" | grep -i 'power_on' | awk '{print $10}')
        if [ -z "$hours_raw" ]; then
            hours_raw=$(smartctl -A "$disk" 2>/dev/null | grep -i 'Power On Hours' | awk '{print $NF}' | tr -d ',')
        fi
        uncorrect=$(echo "$smartout" | grep -i 'Reported_Uncorrect' | awk '{print $10}')
        reallocated=$(echo "$smartout" | grep -i 'Reallocated_Sector' | awk '{print $10}')
        if [ -z "$uncorrect" ]; then
            uncorrect=$(smartctl -A "$disk" 2>/dev/null | grep -i 'Media and Data Integrity Errors' | awk '{print $NF}')
        fi
        [ -z "$uncorrect" ] && uncorrect="0"
        [ -z "$reallocated" ] && reallocated="0"
        hours_fmt=$(hours_to_mdh "${hours_raw:-?}")
        SMART_DATA="${SMART_DATA}${disk}|${health:-N/A}|${temp:-?}°C|${hours_fmt}|${uncorrect}/${reallocated}\n"
        if [ -n "$health" ] && [ "$health" = "FAILED" ]; then
            emit_issue CRIT "$disk SMART health: FAILED"
            SMART_OK="fail"
            SMART_DETAIL="${SMART_DETAIL} ${disk}"
        fi
        if [ "$uncorrect" != "0" ] && [ "$uncorrect" != "" ]; then
            emit_issue WARN "$disk has $uncorrect uncorrectable errors"
        fi
        if [ "$reallocated" != "0" ] && [ "$reallocated" != "" ]; then
            emit_issue WARN "$disk has $reallocated reallocated sectors"
        fi
    done

    for serial in "${!EXPECTED_DISKS[@]}"; do
        found=false
        for fs in "${FOUND_SERIALS[@]}"; do
            if [ "$fs" = "$serial" ]; then
                found=true
                break
            fi
        done
        if ! $found; then
            emit_issue CRIT "Missing disk: ${EXPECTED_DISKS[$serial]} (S/N: $serial)"
            SMART_DATA="${SMART_DATA}MISSING|MISSING|—|—|${EXPECTED_DISKS[$serial]} (S/N: $serial)\n"
        fi
    done
}
check_disks

# --- Syncoid Replication ---
# Exports: SYNCOID_STATUS
check_syncoid_replication() {
    SYNCOID_STATUS="OK"
    [ -z "$SYNCOID_DATASET" ] && { SYNCOID_STATUS="skipped"; return; }
    LAST_SNAP=$(zfs list -t snapshot -o creation "$SYNCOID_DATASET" 2>/dev/null | tail -1 | xargs)
    if [ -z "$LAST_SNAP" ]; then
        emit_issue WARN "No syncoid snapshots on $SYNCOID_DATASET yet"
        SYNCOID_STATUS="No snapshots"
    else
        LAST_EPOCH=$(date -d "$LAST_SNAP" +%s 2>/dev/null)
        NOW_EPOCH=$(date +%s)
        if [ -n "$LAST_EPOCH" ]; then
            AGE_HOURS=$(( (NOW_EPOCH - LAST_EPOCH) / 3600 ))
            SYNCOID_STATUS="${AGE_HOURS}h ago"
            if [ "$AGE_HOURS" -gt 48 ]; then
                emit_issue CRIT "Syncoid replication is ${AGE_HOURS}h old"
            fi
        fi
    fi
}
check_syncoid_replication

# --- Sanoid Snapshot Coverage ---
# Exports: SANOID_TOTAL_DS, SANOID_COVERED_DS, SANOID_UNCOVERED
check_sanoid_coverage() {
    SNAP_COUNT=$(zfs list -t snapshot -o name 2>/dev/null | grep autosnap | wc -l)
    if [ "$SNAP_COUNT" -eq 0 ]; then
        emit_issue CRIT "No sanoid snapshots found"
    fi

    SANOID_MANAGED=$(grep '^\[' /etc/sanoid/sanoid.conf 2>/dev/null | grep -v template | tr -d '[]')
    SANOID_UNCOVERED=""
    SANOID_TOTAL_DS=0
    SANOID_COVERED_DS=0

    ALL_ZFS_GUEST_DS=$(grep -h 'rootfs:\|scsi0:\|virtio0:' /etc/pve/nodes/${PVE_NODE}/qemu-server/*.conf /etc/pve/nodes/${PVE_NODE}/lxc/*.conf 2>/dev/null | grep -oE "${ZFS_POOLS_REGEX}[^ ,]*" | sed 's/:/\//' | sort -u)

    for ds in $ALL_ZFS_GUEST_DS; do
        SANOID_TOTAL_DS=$((SANOID_TOTAL_DS + 1))
        if echo "$SANOID_MANAGED" | grep -qF "$ds"; then
            SANOID_COVERED_DS=$((SANOID_COVERED_DS + 1))
        else
            dsname=$(echo "$ds" | sed 's/.*\///')
            owner=$(grep -rl "$dsname" /etc/pve/nodes/${PVE_NODE}/qemu-server/ /etc/pve/nodes/${PVE_NODE}/lxc/ 2>/dev/null | head -1 | grep -oE '[0-9]+' | tail -1)
            SANOID_UNCOVERED="${SANOID_UNCOVERED}${ds} (VMID ${owner:-?})\n"
        fi
    done

    if [ -n "$SANOID_UNCOVERED" ]; then
        emit_issue WARN "Sanoid: ${SANOID_COVERED_DS}/${SANOID_TOTAL_DS} ZFS guest datasets covered — missing: $(echo -e "$SANOID_UNCOVERED" | tr '\n' ',' | sed 's/,$//')"
    fi
    [ "$SANOID_COVERED_DS" = "$SANOID_TOTAL_DS" ] && SANOID_COV="ok" || SANOID_COV="warn"
}
check_sanoid_coverage

# Helper: timestamp to "Xd Xh ago"
time_ago() {
    local ts="$1"
    [ -z "$ts" ] || [ "$ts" = "n/a" ] && echo "Unknown" && return
    local epoch=$(date -d "$ts" +%s 2>/dev/null)
    [ -z "$epoch" ] && echo "Unknown" && return
    local now=$(date +%s)
    local diff=$(( (now - epoch) / 60 ))
    local mins=$((diff % 60))
    local hrs=$(( (diff / 60) % 24 ))
    local days=$((diff / 1440))
    if [ "$days" -gt 0 ]; then
        echo "${days}d ${hrs}h ago"
    elif [ "$hrs" -gt 0 ]; then
        echo "${hrs}h ${mins}m ago"
    else
        echo "${mins}m ago"
    fi
}

# --- Sanoid Service Status ---
# Exports: SANOID_LAST_FMT, SANOID_LAST_EXIT, SANOID_STATUS_TEXT, SANOID_STATUS_COLOR
check_sanoid_service() {
    SANOID_LAST_RUN=$(systemctl show sanoid.service --property=ExecMainStartTimestamp --value 2>/dev/null)
    SANOID_LAST_EXIT=$(systemctl show sanoid.service --property=ExecMainStatus --value 2>/dev/null)
    SANOID_LAST_FMT=$(time_ago "$SANOID_LAST_RUN")
    if [ "$SANOID_LAST_EXIT" = "0" ]; then
        SANOID_STATUS_TEXT="OK"
        SANOID_STATUS_COLOR="#2ecc71"
        SANOID_OK="ok"
    else
        SANOID_STATUS_TEXT="FAILED (exit $SANOID_LAST_EXIT)"
        SANOID_STATUS_COLOR="#e74c3c"
        SANOID_OK="fail"
        emit_issue CRIT "Sanoid last run failed (exit $SANOID_LAST_EXIT)"
    fi
}
check_sanoid_service

# --- Syncoid Service Status ---
# Exports: SYNCOID_SVC_LAST_FMT, SYNCOID_SVC_LAST_EXIT, SYNCOID_SVC_STATUS_TEXT, SYNCOID_SVC_STATUS_COLOR
check_syncoid_service() {
    SYNCOID_SVC_LAST_RUN=$(systemctl show syncoid-personal.service --property=ExecMainStartTimestamp --value 2>/dev/null)
    SYNCOID_SVC_LAST_EXIT=$(systemctl show syncoid-personal.service --property=ExecMainStatus --value 2>/dev/null)
    SYNCOID_SVC_LAST_FMT=$(time_ago "$SYNCOID_SVC_LAST_RUN")
    if [ "$SYNCOID_SVC_LAST_EXIT" = "0" ]; then
        SYNCOID_SVC_STATUS_TEXT="OK"
        SYNCOID_SVC_STATUS_COLOR="#2ecc71"
        SYNCOID_OK="ok"
    else
        SYNCOID_SVC_STATUS_TEXT="FAILED (exit $SYNCOID_SVC_LAST_EXIT)"
        SYNCOID_SVC_STATUS_COLOR="#e74c3c"
        SYNCOID_OK="fail"
    fi
}
check_syncoid_service

# --- PVE Vzdump Backups ---
# Exports: VZDUMP_VMIDS, TOTAL_GUESTS, VZDUMP_LAST_FMT
check_vzdump() {
    VZDUMP_VMIDS=$(pvesh get /cluster/backup --output-format json 2>/dev/null | python3 -c "
import sys,json
jobs=json.load(sys.stdin)
vmids=set()
for j in jobs:
    for v in j.get('vmid','').split(','):
        if v.strip(): vmids.add(v.strip())
print(len(vmids))
" 2>/dev/null)
    VZDUMP_VMIDS=${VZDUMP_VMIDS:-0}
    TOTAL_GUESTS=$(( $(ls /etc/pve/nodes/${PVE_NODE}/qemu-server/*.conf 2>/dev/null | wc -l) + $(ls /etc/pve/nodes/${PVE_NODE}/lxc/*.conf 2>/dev/null | wc -l) ))
    VZDUMP_LAST=$(ls -t ${VZDUMP_LOG_GLOB} 2>/dev/null | head -1)
    if [ -n "$VZDUMP_LAST" ]; then
        VZDUMP_LAST_TS=$(stat -c '%Y' "$VZDUMP_LAST" 2>/dev/null)
        VZDUMP_LAST_FMT=$(time_ago "$(date -d @"$VZDUMP_LAST_TS" 2>/dev/null)")
    else
        VZDUMP_LAST_FMT="Never"
    fi

    # Last-run status: with per-job emails disabled, this report is the only
    # place a failed vzdump run surfaces.
    local last_status
    last_status=$(pvesh get "/nodes/${PVE_NODE}/tasks" --typefilter vzdump --limit 5 --output-format json 2>/dev/null | python3 -c "
import sys,json
tasks=[t for t in json.load(sys.stdin) if t.get('endtime')]
print(tasks[0].get('status','') if tasks else '')
" 2>/dev/null)
    if [ -n "$last_status" ] && [ "$last_status" != "OK" ]; then
        emit_issue CRIT "Last vzdump run finished with errors: ${last_status}"
    fi

    # Per-guest freshness: every guest in an enabled job must have a backup
    # newer than VZDUMP_MAX_AGE_H on that job's storage (0/unset = disabled).
    local max_age_h="${VZDUMP_MAX_AGE_H:-0}"
    if [ "$max_age_h" -gt 0 ] 2>/dev/null; then
        local storage vmids stale guest msg
        while read -r storage vmids; do
            [ -z "$storage" ] && continue
            stale=$(pvesh get "/nodes/${PVE_NODE}/storage/${storage}/content" --content backup --output-format json 2>/dev/null | python3 -c "
import sys,json,time
newest={}
for e in json.load(sys.stdin):
    v=str(e.get('vmid',''))
    if v: newest[v]=max(newest.get(v,0), e.get('ctime',0))
now=time.time()
for v in '${vmids}'.split(','):
    v=v.strip()
    if not v: continue
    if v not in newest:
        print(f'{v}|has no backup on ${storage}')
    elif (now-newest[v])/3600 > ${max_age_h}:
        print(f'{v}|last backup {(now-newest[v])/86400:.1f}d ago (max ${max_age_h}h)')
" 2>/dev/null)
            while IFS='|' read -r guest msg; do
                [ -z "$guest" ] && continue
                emit_issue WARN "vzdump: guest ${guest} ${msg}"
            done <<< "$stale"
        done <<< "$(pvesh get /cluster/backup --output-format json 2>/dev/null | python3 -c "
import sys,json
for j in json.load(sys.stdin):
    if j.get('enabled',1) and j.get('storage') and j.get('vmid'):
        print(j['storage'], j['vmid'])
" 2>/dev/null)"
    fi
}
check_vzdump

# --- VM/LXC Status ---
# Exports: GUEST_DATA, LXC_UPDATE_SUMMARY, GUEST_OK, GUEST_DETAIL
check_guests() {
    GUEST_OK="ok"; GUEST_DETAIL=""
    GUEST_DATA=""
    for vmid in "${VM_IDS[@]}"; do
        STATUS=$(qm status $vmid 2>/dev/null | awk '{print $2}')
        NAME=$(qm config $vmid 2>/dev/null | grep '^name:' | awk '{print $2}')
        MEM_TOTAL=$(qm config $vmid 2>/dev/null | grep '^memory:' | awk '{print $2}')
        if [ "$STATUS" = "running" ]; then
            # QEMU guest agent liveness: if the VM is configured for the agent
            # (agent: enabled=1) but the in-guest daemon isn't answering, then
            # qm guest exec (our deploy path), fs-freeze quiesced backups and
            # graceful shutdown all silently break while the VM looks healthy.
            if qm config $vmid 2>/dev/null | grep '^agent:' | grep -q 'enabled=1' \
               && ! qm agent $vmid ping >/dev/null 2>&1; then
                emit_issue WARN "VM $vmid ($NAME) QEMU guest agent not responding (enabled but down - breaks deploys/backups/graceful shutdown)"
            fi
            MEM_USED_MB=$(qm guest exec $vmid -- free -m 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); lines=d.get('out-data','').split('\n'); mem=[l for l in lines if l.startswith('Mem:')]; print(mem[0].split()[2]) if mem else print(0)" 2>/dev/null)
            MEM_USED_MB=${MEM_USED_MB:-0}
            if [ "$MEM_TOTAL" -ge 1024 ]; then
                MEM_USED_G=$(awk "BEGIN {printf \"%.1f\", $MEM_USED_MB/1024}")
                MEM_TOTAL_G=$((MEM_TOTAL / 1024))
                MEM_STR="${MEM_USED_G}/${MEM_TOTAL_G}G"
            else
                MEM_STR="${MEM_USED_MB}/${MEM_TOTAL}M"
            fi
            if in_array "$vmid" "${HASS_OS_VM_IDS[@]}"; then
                DISK_RAW=$(qm guest exec $vmid -- df -h /mnt/data 2>/dev/null)
            else
                DISK_RAW=$(qm guest exec $vmid -- df -h / 2>/dev/null)
            fi
            DISK_INFO=$(echo "$DISK_RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); lines=d.get('out-data','').strip().split('\n'); parts=lines[-1].split() if len(lines)>1 else []; print(f'{parts[2]}/{parts[1]}') if len(parts)>=4 else print('?/?')" 2>/dev/null)
            DISK_PCT=$(echo "$DISK_RAW" | python3 -c "import sys,json; d=json.load(sys.stdin); lines=d.get('out-data','').strip().split('\n'); parts=lines[-1].split() if len(lines)>1 else []; pct=parts[4].rstrip('%') if len(parts)>=5 else '0'; print(pct)" 2>/dev/null)
            [ -n "$DISK_PCT" ] && [ "$DISK_INFO" != "?/?" ] && DISK_INFO="${DISK_INFO} (${DISK_PCT}%)"
            if [ -n "$DISK_PCT" ] && [ "$DISK_PCT" -ge 95 ] 2>/dev/null; then
                emit_issue CRIT "VM $vmid ($NAME) disk at ${DISK_PCT}%"
            elif [ -n "$DISK_PCT" ] && [ "$DISK_PCT" -ge 85 ] 2>/dev/null; then
                emit_issue WARN "VM $vmid ($NAME) disk at ${DISK_PCT}%"
            fi
        else
            if [ "$MEM_TOTAL" -ge 1024 ]; then
                MEM_STR="-/${MEM_TOTAL_G:-$((MEM_TOTAL / 1024))}G"
            else
                MEM_STR="-/${MEM_TOTAL}M"
            fi
            DISK_INFO="-"
        fi
        GUEST_DATA="${GUEST_DATA}${NAME}|${STATUS}|${MEM_STR}|${DISK_INFO}\n"
        if ! in_array "$vmid" "${VM_EXPECTED_STOPPED[@]}" && [ "$STATUS" != "running" ]; then
            emit_issue CRIT "VM $vmid ($NAME) is $STATUS"
            GUEST_OK="fail"
            GUEST_DETAIL="${GUEST_DETAIL} ${NAME}"
        fi
    done
    LXC_UPDATE_SUMMARY=""
    for ctid in $(pct list 2>/dev/null | awk 'NR>1 {print $1}' | sort -n); do
        STATUS=$(pct status $ctid 2>/dev/null | awk '{print $2}')
        NAME=$(pct config $ctid 2>/dev/null | grep '^hostname:' | awk '{print $2}')
        MEM_TOTAL=$(pct config $ctid 2>/dev/null | grep '^memory:' | awk '{print $2}')
        if [ "$STATUS" = "running" ]; then
            MEM_USED_MB=$(pct exec $ctid -- free -m 2>/dev/null | awk '/Mem:/ {print $3}')
            MEM_USED_MB=${MEM_USED_MB:-0}
            if [ "$MEM_TOTAL" -ge 1024 ]; then
                MEM_USED_G=$(awk "BEGIN {printf \"%.1f\", $MEM_USED_MB/1024}")
                MEM_TOTAL_G=$((MEM_TOTAL / 1024))
                MEM_STR="${MEM_USED_G}/${MEM_TOTAL_G}G"
            else
                MEM_STR="${MEM_USED_MB}/${MEM_TOTAL}M"
            fi
            DISK_INFO=$(pct exec $ctid -- df -h / 2>/dev/null | awk 'NR==2 {print $3"/"$2}')
            DISK_PCT=$(pct exec $ctid -- df / 2>/dev/null | awk 'NR==2 {gsub(/%/,""); print $5}')
            [ -n "$DISK_PCT" ] && [ -n "$DISK_INFO" ] && DISK_INFO="${DISK_INFO} (${DISK_PCT}%)"
            if [ -n "$DISK_PCT" ] && [ "$DISK_PCT" -ge 95 ] 2>/dev/null; then
                emit_issue CRIT "LXC $ctid ($NAME) disk at ${DISK_PCT}%"
            elif [ -n "$DISK_PCT" ] && [ "$DISK_PCT" -ge 85 ] 2>/dev/null; then
                emit_issue WARN "LXC $ctid ($NAME) disk at ${DISK_PCT}%"
            fi
            LXC_UPG_COUNT=$(pct exec $ctid -- bash -c 'apt-get -s dist-upgrade 2>/dev/null | grep -c ^Inst' 2>/dev/null)
            LXC_UPG_COUNT=${LXC_UPG_COUNT:-0}
            if [ "$LXC_UPG_COUNT" -gt 0 ] 2>/dev/null; then
                emit_issue WARN "LXC $ctid ($NAME) has ${LXC_UPG_COUNT} pending apt update(s)"
                LXC_UPDATE_SUMMARY="${LXC_UPDATE_SUMMARY}${NAME}:${LXC_UPG_COUNT} "
            fi
        else
            if [ "$MEM_TOTAL" -ge 1024 ]; then
                MEM_STR="-/${MEM_TOTAL_G:-$((MEM_TOTAL / 1024))}G"
            else
                MEM_STR="-/${MEM_TOTAL}M"
            fi
            DISK_INFO="-"
        fi
        GUEST_DATA="${GUEST_DATA}${NAME}|${STATUS}|${MEM_STR}|${DISK_INFO}\n"
        if [ "$STATUS" != "running" ]; then
            emit_issue CRIT "LXC $ctid ($NAME) is $STATUS"
            GUEST_OK="fail"
            GUEST_DETAIL="${GUEST_DETAIL} ${NAME}"
        fi
    done
    LXC_UPDATE_SUMMARY="${LXC_UPDATE_SUMMARY% }"
}
check_guests

# --- Postfix Queue ---
check_postfix_queue() {
    local deferred
    deferred=$(postqueue -p 2>/dev/null | tail -1)
    if echo "$deferred" | grep -qE "[0-9]+ Request"; then
        emit_issue WARN "Deferred mail in queue: $deferred"
    fi
}
check_postfix_queue

# --- Docker Container Health (VM 104 + LXC 105) ---
# Exports: DOCKER_CRIT_DATA, DOCKER_CRIT_COUNT, DOCKER_CRIT_UP, DOCKER_OTHER_RUNNING,
#          DOCKER_OTHER_TOTAL, DOCKER_STOPPED_DATA, DOCKER_PS (non-empty = any host scanned)
# Helper: inspect-row format (name|state|health|exit|restart); scan_docker_host parses it
_DOCKER_FMT='{{.Name}}|{{.State.Status}}|{{if .State.Health}}{{.State.Health.Status}}{{else}}-{{end}}|{{.State.ExitCode}}|{{.HostConfig.RestartPolicy.Name}}'

scan_docker_host() {
    local host_label="$1"
    local inspect_output="$2"
    local dname dstate dhealth exit_code restart_pol is_crit stop_reason pat ex
    while IFS='|' read -r dname dstate dhealth exit_code restart_pol; do
        [ -z "$dname" ] && continue
        dname="${dname#/}"
        is_crit=false
        for pat in "${DOCKER_CRITICAL_PATTERNS[@]}"; do
            # shellcheck disable=SC2053
            if [[ "$dname" == $pat ]]; then
                is_crit=true
                for ex in "${DOCKER_CRITICAL_EXCLUDE[@]}"; do
                    # shellcheck disable=SC2053
                    if [[ "$dname" == $ex ]]; then is_crit=false; break; fi
                done
                break
            fi
        done
        if $is_crit; then
            DOCKER_CRIT_COUNT=$((DOCKER_CRIT_COUNT + 1))
            DOCKER_CRIT_DATA="${DOCKER_CRIT_DATA}${dname}|${dstate}\n"
            if [ "$dstate" = "running" ]; then
                if [ "$dhealth" = "unhealthy" ]; then
                    emit_issue CRIT "Docker critical: ${dname} is unhealthy (${host_label})"
                else
                    DOCKER_CRIT_UP=$((DOCKER_CRIT_UP + 1))
                fi
            else
                emit_issue CRIT "Docker critical: ${dname} is ${dstate} (${host_label})"
            fi
        else
            DOCKER_OTHER_TOTAL=$((DOCKER_OTHER_TOTAL + 1))
            if [ "$dstate" = "running" ]; then
                if [ "$dhealth" = "unhealthy" ]; then
                    emit_issue WARN "Docker container unhealthy: ${dname} (${host_label})"
                    DOCKER_STOPPED_DATA="${DOCKER_STOPPED_DATA}${dname}|unhealthy\n"
                else
                    DOCKER_OTHER_RUNNING=$((DOCKER_OTHER_RUNNING + 1))
                fi
            else
                if [ "$restart_pol" = "no" ] && [ "$exit_code" = "0" ]; then
                    stop_reason="manual"
                elif [ "$exit_code" != "0" ] && [ -n "$exit_code" ]; then
                    stop_reason="crashed (exit ${exit_code})"
                    emit_issue WARN "Docker container crashed: ${dname} (exit ${exit_code}, ${host_label})"
                elif [ "$dstate" = "restarting" ]; then
                    stop_reason="crash loop"
                    emit_issue CRIT "Docker container in crash loop: ${dname} (${host_label})"
                else
                    stop_reason="stopped"
                fi
                DOCKER_STOPPED_DATA="${DOCKER_STOPPED_DATA}${dname}|${stop_reason}\n"
            fi
        fi
    done <<< "$inspect_output"
}

check_docker() {
    DOCKER_CRIT_DATA=""
    DOCKER_OTHER_RUNNING=0
    DOCKER_OTHER_TOTAL=0
    DOCKER_CRIT_COUNT=0
    DOCKER_CRIT_UP=0
    DOCKER_STOPPED_DATA=""
    DOCKER_PS=""

    if [ -n "$DOCKER_VM" ] && qm status "$DOCKER_VM" 2>/dev/null | grep -q running; then
        VM_INSPECT=$(qm guest exec "$DOCKER_VM" -- bash -c "docker ps -aq | xargs -r docker inspect --format '${_DOCKER_FMT}'" 2>/dev/null | \
            python3 -c "import sys,json; print(json.load(sys.stdin).get('out-data',''))" 2>/dev/null)
        if [ -n "$VM_INSPECT" ]; then
            scan_docker_host "VM $DOCKER_VM" "$VM_INSPECT"
            DOCKER_PS="$VM_INSPECT"
        fi
    fi

    if [ -n "$DOCKER_IN_LXC" ] && pct status "$DOCKER_IN_LXC" 2>/dev/null | grep -q running; then
        LXC_INSPECT=$(pct exec "$DOCKER_IN_LXC" -- bash -c "docker ps -aq | xargs -r docker inspect --format '${_DOCKER_FMT}'" 2>/dev/null)
        if [ -n "$LXC_INSPECT" ]; then
            scan_docker_host "LXC $DOCKER_IN_LXC" "$LXC_INSPECT"
            DOCKER_PS="${DOCKER_PS}${LXC_INSPECT}"
        fi
    fi
}
check_docker

# --- Service Health Checks ---
check_services() {
    local ha_http pg_ready
    if [ -n "$HA_URL" ]; then
        ha_http=$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 5 --max-time 10 "$HA_URL" 2>/dev/null)
        if [ "$ha_http" != "200" ] && [ "$ha_http" != "401" ] && [ "$ha_http" != "403" ]; then
            emit_issue CRIT "Home Assistant not responding (HTTP ${ha_http:-timeout})"
        fi
    fi
    # HA Assist (Ollama conversation agent) — catches the layer where Ollama is healthy
    # but the HA integration has drifted (e.g. LXC IP changed, model removed).
    # Silently skipped if HA_TOKEN unset.
    if [ -n "$HA_URL" ] && [ -n "$HA_TOKEN" ]; then
        local base="${HA_URL%/}"
        local entity="${HA_ASSIST_ENTITY:-conversation.ollama_conversation}"
        HA_TOKEN="$HA_TOKEN" HA_BASE="$base" HA_ENTITY="$entity" python3 - <<'PYEOF' | while IFS= read -r line; do [ -n "$line" ] && ISSUES+=("$line"); done
import os, json, urllib.request

base = os.environ["HA_BASE"]
hdr = {"Authorization": f"Bearer {os.environ['HA_TOKEN']}"}

def get(path):
    r = urllib.request.Request(base + path, headers=hdr)
    return json.loads(urllib.request.urlopen(r, timeout=8).read())

try:
    entries = get("/config/config_entries/entry?domain=ollama")
    if not entries:
        print("WARN|HA Ollama integration not configured")
    else:
        for e in entries:
            st = e.get("state", "?")
            if st in ("setup_error", "setup_retry", "migration_error", "failed_unload"):
                print(f"CRIT|HA Ollama integration in state '{st}' (entry {e.get('title','?')})")
            elif st != "loaded":
                print(f"WARN|HA Ollama integration in state '{st}'")
except Exception as ex:
    print(f"WARN|HA Ollama integration check failed: {type(ex).__name__}")

try:
    s = get(f"/states/{os.environ['HA_ENTITY']}")
    state = s.get("state", "?")
    if state == "unavailable":
        print(f"CRIT|HA conversation entity {os.environ['HA_ENTITY']} is unavailable")
except urllib.error.HTTPError as ex:
    if ex.code == 404:
        print(f"WARN|HA conversation entity {os.environ['HA_ENTITY']} not found")
    else:
        print(f"WARN|HA conversation entity check failed: HTTP {ex.code}")
except Exception as ex:
    print(f"WARN|HA conversation entity check failed: {type(ex).__name__}")
PYEOF
    fi
    if [ -n "$POSTGRES_LXC" ] && pct status "$POSTGRES_LXC" 2>/dev/null | grep -q running; then
        pg_ready=$(pct exec "$POSTGRES_LXC" -- pg_isready 2>&1)
        if ! echo "$pg_ready" | grep -q "accepting connections"; then
            emit_issue CRIT "PostgreSQL (LXC $POSTGRES_LXC) not accepting connections"
        fi
    fi
    if ! nvidia-smi --query-gpu=name --format=csv,noheader &>/dev/null; then
        emit_issue WARN "NVIDIA GPU driver not responding"
    fi
    if [ -n "${AMD_KFD_LXCS[*]}" ] && [ ! -e /dev/kfd ]; then
        emit_issue WARN "AMD GPU /dev/kfd missing (driver issue)"
    fi
}
check_services

# Samba - server-side regression detector. Catches smbd/nmbd crashes, port not
# listening, or a share name disappearing from the advertised list (e.g. typo
# in smb.conf after edit, path no longer exists). Skipped if SAMBA_SHARES empty.
check_samba() {
    [ -z "${SAMBA_SHARES[*]}" ] && return
    if ! systemctl is-active --quiet smbd; then
        emit_issue CRIT "smbd not active"
        return
    fi
    if ! systemctl is-active --quiet nmbd; then
        emit_issue WARN "nmbd not active"
    fi
    if ! ss -tln 2>/dev/null | grep -qE ':445\b'; then
        emit_issue CRIT "Samba TCP 445 not listening"
        return
    fi
    local advertised
    advertised=$(timeout 5 smbclient -L //localhost -U% 2>/dev/null | awk '/Disk/ {print $1}')
    if [ -z "$advertised" ]; then
        emit_issue WARN "smbclient -L //localhost returned no shares"
        return
    fi
    local share
    for share in "${SAMBA_SHARES[@]}"; do
        if ! grep -qx "$share" <<< "$advertised"; then
            emit_issue WARN "Samba share '${share}' not advertised"
        fi
    done
}
check_samba

# GPU cgroup major number mismatch (dynamic majors shift across reboots)
check_gpu_cgroup_majors() {
    local nvuvm_major kfd_major stale ct_name ctid
    if [ -e /dev/nvidia-uvm ] && [ -n "${NVIDIA_UVM_LXCS[*]}" ]; then
        nvuvm_major=$(stat -c '%Hr' /dev/nvidia-uvm)
        for ctid in "${NVIDIA_UVM_LXCS[@]}"; do
            if ! grep -qP "lxc\\.cgroup2\\.devices\\.allow: c ${nvuvm_major}:\\*" /etc/pve/lxc/${ctid}.conf 2>/dev/null; then
                stale=$(grep 'lxc.cgroup2.devices.allow:' /etc/pve/lxc/${ctid}.conf 2>/dev/null | grep -vE 'c (195|226|189|510):' | grep -oP 'c \K[0-9]+' | head -1)
                ct_name=$(pct config $ctid 2>/dev/null | grep '^hostname:' | awk '{print $2}')
                emit_issue CRIT "LXC ${ctid} (${ct_name}) nvidia-uvm cgroup major mismatch: config has ${stale:-?}, actual is ${nvuvm_major} — GPU decoding broken, restart LXC after running fix-lxc-gpu-majors"
            fi
        done
    fi
    if [ -e /dev/kfd ] && [ -n "${AMD_KFD_LXCS[*]}" ]; then
        kfd_major=$(stat -c '%Hr' /dev/kfd)
        for ctid in "${AMD_KFD_LXCS[@]}"; do
            if ! grep -qP "lxc\\.cgroup2\\.devices\\.allow: c ${kfd_major}:\\*" /etc/pve/lxc/${ctid}.conf 2>/dev/null; then
                stale=$(grep 'lxc.cgroup2.devices.allow:' /etc/pve/lxc/${ctid}.conf 2>/dev/null | grep -vE 'c 226:' | grep -oP 'c \K[0-9]+' | head -1)
                ct_name=$(pct config $ctid 2>/dev/null | grep '^hostname:' | awk '{print $2}')
                emit_issue CRIT "LXC ${ctid} (${ct_name}) KFD cgroup major mismatch: config has ${stale:-?}, actual is ${kfd_major} — AMD GPU broken, restart LXC after running fix-lxc-gpu-majors"
            fi
        done
    fi
}
check_gpu_cgroup_majors
# TLS certificate expiry (check from Docker VM)
if [ -n "$DOCKER_PS" ]; then
    DOCKER_VM_IP=$(qm guest exec 104 -- hostname -I 2>/dev/null | \
        python3 -c "import sys,json; d=json.load(sys.stdin); ips=d.get('out-data','').strip().split(); print(ips[0] if ips else '')" 2>/dev/null)
    if [ -n "$DOCKER_VM_IP" ]; then
        CERT_END=$(echo | openssl s_client -connect "${DOCKER_VM_IP}:443" 2>/dev/null | \
            openssl x509 -noout -enddate 2>/dev/null | cut -d= -f2)
        if [ -n "$CERT_END" ]; then
            CERT_EPOCH=$(date -d "$CERT_END" +%s 2>/dev/null)
            CERT_DAYS=$(( (CERT_EPOCH - $(date +%s)) / 86400 ))
            if [ "$CERT_DAYS" -lt 7 ]; then
                ISSUES+=("CRIT|TLS cert expires in ${CERT_DAYS} days")
            elif [ "$CERT_DAYS" -lt 14 ]; then
                ISSUES+=("WARN|TLS cert expires in ${CERT_DAYS} days")
            fi
        fi
    fi
fi

