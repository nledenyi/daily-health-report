# Syncthing (shared Docker container behind the PVE node or on the Docker VM)
# Skipped entirely unless both a URL can be resolved and the config XML is readable.
_st_url="${SYNCTHING_URL}"
[ -z "$_st_url" ] && [ -n "$DOCKER_VM_IP" ] && _st_url="http://${DOCKER_VM_IP}:8384"
if [ -n "$_st_url" ] && [ -r "$SYNCTHING_CONFIG_XML" ]; then
    ST_APIKEY=$(grep -oP "<apikey>\K[^<]+" "$SYNCTHING_CONFIG_XML" 2>/dev/null | head -1)
    if [ -n "$ST_APIKEY" ]; then
        while IFS= read -r line; do
            [ -n "$line" ] && ISSUES+=("$line")
        done < <(ST_APIKEY="$ST_APIKEY" ST_URL="$_st_url" SYNCTHING_IGNORE_PEERS="$SYNCTHING_IGNORE_PEERS" python3 - <<'PYEOF'
import os, sys, json, urllib.request
from datetime import datetime, timezone

URL = os.environ['ST_URL']
KEY = os.environ['ST_APIKEY']

def get(path):
    req = urllib.request.Request(URL + path, headers={'X-API-Key': KEY})
    with urllib.request.urlopen(req, timeout=10) as r:
        return json.loads(r.read())

try:
    if get('/rest/system/ping').get('ping') != 'pong':
        print('CRIT|Syncthing API ping returned unexpected response')
        sys.exit(0)
except Exception as e:
    print(f'CRIT|Syncthing API unreachable ({type(e).__name__})')
    sys.exit(0)

try:
    sys_errs = get('/rest/system/error').get('errors') or []
    if sys_errs:
        print(f'WARN|Syncthing: {len(sys_errs)} system-level error(s)')
except Exception:
    pass

try:
    for f in get('/rest/config/folders'):
        st = get(f"/rest/db/status?folder={f['id']}")
        pe = st.get('pullErrors', 0)
        if pe > 0:
            print(f"WARN|Syncthing folder '{f['label']}': {pe} pull error(s)")
except Exception:
    pass

try:
    ignore = {n.strip() for n in os.environ.get('SYNCTHING_IGNORE_PEERS', '').split(',') if n.strip()}
    devices = {d['deviceID']: d['name'] for d in get('/rest/config/devices')}
    conns = get('/rest/system/connections').get('connections', {})
    stats = get('/rest/stats/device')
    now = datetime.now(timezone.utc)
    for dev_id, info in conns.items():
        if info.get('connected') or info.get('paused'):
            continue
        name = devices.get(dev_id, dev_id[:8])
        if name in ignore:
            continue
        last = (stats.get(dev_id) or {}).get('lastSeen') or info.get('lastSeen') or ''
        if not last or last.startswith('0001'):
            print(f"WARN|Syncthing peer '{name}' has never connected")
            continue
        try:
            dt = datetime.fromisoformat(last.replace('Z', '+00:00'))
            hrs = int((now - dt).total_seconds() / 3600)
            if hrs > 24:
                print(f"WARN|Syncthing peer '{name}' offline {hrs}h")
        except Exception:
            pass
except Exception:
    pass
PYEOF
)
    fi
fi

# --- Unattended Upgrades + Package NEWS ---
# Exports: UAU_PKG_COUNT, UAU_REBOOT_REQUIRED, UAU_LAST_FMT, UAU_LAST_EXIT,
#          UAU_STATUS_TEXT, UAU_STATUS_COLOR, APT_NEWS, APT_NEWS_COUNT
check_upgrades() {
    UAU_LOG="/var/log/unattended-upgrades/unattended-upgrades.log"
    UAU_TODAY=$(date '+%Y-%m-%d')
    UAU_UPGRADED=""
    UAU_ERROR=""
    UAU_PKG_COUNT=0
    if [ -f "$UAU_LOG" ]; then
        UAU_TODAY_LOG=$(grep "^${UAU_TODAY}" "$UAU_LOG" 2>/dev/null)
        UAU_UPGRADED=$(echo "$UAU_TODAY_LOG" | grep -oP 'Packages that will be upgraded: \K.*' | tail -1)
        if [ -n "$UAU_UPGRADED" ]; then
            UAU_PKG_COUNT=$(echo "$UAU_UPGRADED" | wc -w)
        fi
        if echo "$UAU_TODAY_LOG" | grep -qiE 'ERROR|WARNING.*dpkg|failed'; then
            UAU_ERROR=$(echo "$UAU_TODAY_LOG" | grep -iE 'ERROR|WARNING.*dpkg|failed' | tail -1)
        fi
    fi
    UAU_REBOOT_REQUIRED="no"
    if [ -f /var/run/reboot-required ]; then
        UAU_REBOOT_REQUIRED="yes"
        emit_issue WARN "Reboot required (unattended-upgrades)"
    fi
    if [ -n "$UAU_ERROR" ]; then
        emit_issue CRIT "Unattended-upgrades error: ${UAU_ERROR}"
    fi

    # Package NEWS (apt-listchanges replacement)
    APT_NEWS=""
    APT_NEWS_COUNT=0
    if [ -f /var/log/dpkg.log ]; then
        YESTERDAY=$(date -d '24 hours ago' '+%Y-%m-%d %H:%M:%S')
        RECENT_PKGS=$(awk -v since="$YESTERDAY" '$0 >= since && / upgrade / {print $4}' /var/log/dpkg.log 2>/dev/null | sort -u)
        for pkg in $RECENT_PKGS; do
            news_file="/usr/share/doc/${pkg}/NEWS.Debian.gz"
            if [ -f "$news_file" ]; then
                APT_NEWS="${APT_NEWS}${pkg}, "
                APT_NEWS_COUNT=$((APT_NEWS_COUNT + 1))
            fi
        done
        APT_NEWS="${APT_NEWS%, }"
    fi
    if [ "$APT_NEWS_COUNT" -gt 0 ]; then
        emit_issue INFO "${APT_NEWS_COUNT} upgraded package(s) with NEWS: ${APT_NEWS}"
    fi

    # Status for maintenance table
    UAU_LAST_RUN=$(systemctl show apt-daily-upgrade.service --property=ExecMainStartTimestamp --value 2>/dev/null)
    UAU_LAST_EXIT=$(systemctl show apt-daily-upgrade.service --property=ExecMainStatus --value 2>/dev/null)
    UAU_LAST_FMT=$(time_ago "$UAU_LAST_RUN")
    if [ -n "$UAU_ERROR" ]; then
        UAU_STATUS_TEXT="ERROR"
        UAU_STATUS_COLOR="#e74c3c"
    elif [ "$UAU_PKG_COUNT" -gt 0 ]; then
        UAU_STATUS_TEXT="${UAU_PKG_COUNT} upgraded"
        UAU_STATUS_COLOR="#3498db"
    elif [ "$UAU_LAST_EXIT" = "0" ]; then
        UAU_STATUS_TEXT="OK (no updates)"
        UAU_STATUS_COLOR="#2ecc71"
    else
        UAU_STATUS_TEXT="OK (no updates)"
        UAU_STATUS_COLOR="#2ecc71"
    fi
}
check_upgrades

# --- ZFS Scrub Status ---
# Exports: SCRUB_DATA
check_scrub() {
    SCRUB_DATA=""
    while read -r pool; do
        [ -z "$pool" ] && continue
        scrub_line=$(zpool status "$pool" 2>/dev/null | grep -A1 'scan:' | head -2)
        scrub_date=$(echo "$scrub_line" | grep -oP 'on \K\w+ \w+ +\d+ \d+:\d+:\d+ \d+' | head -1)
        scrub_errors=$(echo "$scrub_line" | grep -oP '\d+ errors' | head -1)
        if [ -n "$scrub_date" ]; then
            scrub_fmt=$(time_ago "$scrub_date")
            scrub_errs="${scrub_errors:-0 errors}"
        else
            scrub_fmt="Never"
            scrub_errs="—"
        fi
        SCRUB_DATA="${SCRUB_DATA}${pool}|${scrub_fmt}|${scrub_errs}\n"
        if [ -n "$scrub_errors" ] && [ "$scrub_errors" != "0 errors" ]; then
            emit_issue WARN "ZFS scrub on $pool reported $scrub_errors"
        fi
    done <<< "$(zpool list -H -o name)"
}
check_scrub


# --- Ollama (LXC 106) ---
# Exports: OLLAMA_OK + 15 OLLAMA_* fields used by the Ollama section renderer
check_ollama() {
    OLLAMA_OK="unknown"
    OLLAMA_VERSION=""
    OLLAMA_MODELS_COUNT=0
    OLLAMA_MODELS_SIZE=""
    OLLAMA_LOADED_MODELS=""
    OLLAMA_GPU_OFFLOAD=""
    OLLAMA_REQ_24H=0
    OLLAMA_ERR_24H=0
    OLLAMA_IDLE_TIME=""
    OLLAMA_AVG_DURATION=""
    OLLAMA_CLIENTS=""
    OLLAMA_TOKENS_GENERATED=0
    OLLAMA_TOKENS_PROMPT=0
    OLLAMA_TOK_PER_SEC=""

    [ -z "$OLLAMA_API" ] && { OLLAMA_OK="skipped"; return; }

    if [ -n "$OLLAMA_LXC" ] && ! pct status "$OLLAMA_LXC" 2>/dev/null | grep -q running; then
        OLLAMA_OK="fail"
        emit_issue CRIT "Ollama LXC $OLLAMA_LXC is not running"
        return
    fi

    OLLAMA_VERSION=$(curl -s --connect-timeout 3 "${OLLAMA_API}/api/version" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('version','?'))" 2>/dev/null)
    if [ -z "$OLLAMA_VERSION" ] || [ "$OLLAMA_VERSION" = "?" ]; then
        OLLAMA_OK="fail"
        emit_issue CRIT "Ollama API ($OLLAMA_API) not responding"
        return
    fi
    OLLAMA_OK="ok"

    OLLAMA_LATEST=$(curl -s --connect-timeout 5 "$OLLAMA_RELEASES_API" 2>/dev/null | python3 -c "import sys,json; print(json.load(sys.stdin).get('tag_name','').lstrip('v'))" 2>/dev/null)
    OLLAMA_UPDATE_AVAIL=""
    if [ -n "$OLLAMA_LATEST" ] && [ "$OLLAMA_LATEST" != "$OLLAMA_VERSION" ]; then
        if [ "${OLLAMA_VERSION%.*}" != "${OLLAMA_LATEST%.*}" ]; then
            # Minor/major bump - needs a coordinated GPU test, warn only
            OLLAMA_UPDATE_AVAIL="$OLLAMA_LATEST"
            emit_issue WARN "Ollama update available: ${OLLAMA_VERSION} -> ${OLLAMA_LATEST}"
        elif [ -n "$OLLAMA_UPGRADE_HOOK" ] && [ -x "$OLLAMA_UPGRADE_HOOK" ]; then
            # Patch release - apply silently via the external upgrade hook
            if timeout 1800 "$OLLAMA_UPGRADE_HOOK" "$OLLAMA_LATEST" >/dev/null 2>&1; then
                OLLAMA_VERSION="$OLLAMA_LATEST"
                emit_issue INFO "Ollama patch-upgraded to ${OLLAMA_LATEST}"
            else
                OLLAMA_UPDATE_AVAIL="$OLLAMA_LATEST"
                emit_issue WARN "Ollama patch auto-upgrade to ${OLLAMA_LATEST} failed - upgrade manually"
            fi
        else
            # Patch release, no upgrade hook configured
            OLLAMA_UPDATE_AVAIL="$OLLAMA_LATEST"
            emit_issue WARN "Ollama update available: ${OLLAMA_VERSION} -> ${OLLAMA_LATEST}"
        fi
    fi

    TAGS_JSON=$(curl -s --connect-timeout 3 "${OLLAMA_API}/api/tags" 2>/dev/null)
    OLLAMA_MODELS_COUNT=$(echo "$TAGS_JSON" | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d.get('models',[])))" 2>/dev/null)
