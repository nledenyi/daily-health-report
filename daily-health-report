# Claude Code session-transcripts backup (rsync mirror to ZFS-backed pool, cron 02:45)
check_claude_projects_backup() {
    local sentinel=/var/log/claude-projects-backup.last-success
    if [ ! -f "$sentinel" ]; then
        emit_issue CRIT "claude-projects backup sentinel missing — has the cron ever succeeded?"
        return
    fi
    local age_h=$(( ( $(date +%s) - $(stat -c '%Y' "$sentinel") ) / 3600 ))
    if [ "$age_h" -gt 36 ]; then
        emit_issue CRIT "claude-projects backup last succeeded ${age_h}h ago"
    elif [ "$age_h" -gt 26 ]; then
        emit_issue WARN "claude-projects backup last succeeded ${age_h}h ago"
    fi
}
check_claude_projects_backup

